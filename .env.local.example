# Core
NODE_ENV=development

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# MongoDB (used by chat/history APIs)
MONGODB_URI=mongodb://127.0.0.1:27017/eva

# Optional voice providers
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
ELEVENLABS_API_KEY=

# Voice fallback toggles (disabled by default for free-first mode)
NEXT_PUBLIC_ENABLE_SERVER_STT=false
NEXT_PUBLIC_ENABLE_SERVER_TTS=false

# Data stores (Phase 2)
DATABASE_URL=
REDIS_URL=
